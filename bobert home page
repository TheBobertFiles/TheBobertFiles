<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bobert Files</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
    }

    h1 {
      margin-bottom: 40px;
      font-size: 2.5rem;
      letter-spacing: 2px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(2, 200px);
      gap: 20px;
    }

    .card {
      background: #1e293b;
      padding: 40px;
      text-align: center;
      border-radius: 16px;
      text-decoration: none;
      color: white;
      font-size: 1.2rem;
      transition: 0.3s ease;
    }

    .card:hover {
      background: #334155;
      transform: translateY(-5px);
    }
  </style>
</head>
<body>

  <h1>Welcome to the Bobert Files</h1>

  <div class="grid">
    <a href="file-a.html" class="card">File A</a>
    <a href="file-b.html" class="card">File B</a>
    <a href="file-c.html" class="card">File C</a>
    <a href="file-d.html" class="card">File D</a>
  </div>

</body>
</html>
